# ==========================================================
# .gitignore for Python + PyCharm Project
# ==========================================================

# ----------------------------------------------------------
# Python Bytecode
# ----------------------------------------------------------
__init__.py
__pycache__/
*.py[cod]
*$py.class

# ----------------------------------------------------------
# C Extensions
# ----------------------------------------------------------
*.so

# ----------------------------------------------------------
# Distribution / Packaging
# ----------------------------------------------------------
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
pip-wheel-metadata/
*.egg-info/
.installed.cfg
*.egg

# ----------------------------------------------------------
# Virtual Environments
# ----------------------------------------------------------
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# ----------------------------------------------------------
# Environment Variables
# ----------------------------------------------------------
.env
.env.*
*.env

# ----------------------------------------------------------
# PyCharm
# ----------------------------------------------------------
.idea/
*.iml

# ----------------------------------------------------------
# VS Code (Optional)
# ----------------------------------------------------------
.vscode/

# ----------------------------------------------------------
# Jupyter Notebook
# ----------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------
# Unit Test / Coverage
# ----------------------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# ----------------------------------------------------------
# Type Checkers
# ----------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ----------------------------------------------------------
# Linter Cache
# ----------------------------------------------------------
.ruff_cache/

# ----------------------------------------------------------
# Documentation
# ----------------------------------------------------------
docs/_build/

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
*.log
logs/

# ----------------------------------------------------------
# Database Files
# ----------------------------------------------------------
*.sqlite3
*.db

# ----------------------------------------------------------
# OS Generated Files
# ----------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ----------------------------------------------------------
# Build Artifacts
# ----------------------------------------------------------
*.manifest
*.spec

# ----------------------------------------------------------
# Python Installer Logs
# ----------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# ----------------------------------------------------------
# Profiling
# ----------------------------------------------------------
.prof

# ----------------------------------------------------------
# Local Configuration
# ----------------------------------------------------------
.python-version

# ----------------------------------------------------------
# Editor Backup Files
# ----------------------------------------------------------
*.orig
*.rej

# ----------------------------------------------------------
# macOS
# ----------------------------------------------------------
.AppleDouble
.LSOverride

# ----------------------------------------------------------
# Windows
# ----------------------------------------------------------
ehthumbs.db